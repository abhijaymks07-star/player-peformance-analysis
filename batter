                self.player_data = pd.read_csv(player_file)
                print(f"✓ Loaded {len(self.player_data)} player records")
                
                # Clean player data
                self.player_data['bat_style'] = self.player_data['bat_style'].fillna('Unknown')
                self.player_data['bowl_style'] = self.player_data['bowl_style'].fillna('Unknown')
                self.player_data['playing_role'] = self.player_data['playing_role'].fillna('Unknown')
                
            except Exception as e:
                print(f"⚠ Player metadata file error: {e}")
                self.player_data = pd.DataFrame(columns=['player_name', 'bat_style', 'bowl_style', 'playing_role'])
            
            # Prepare data for analysis
            self.prepare_data()
            
        except FileNotFoundError as e:
            print(f"Error: {e}")
            print("Creating sample data for demonstration...")
            self.create_sample_data()
            
    def prepare_data(self):
        """Prepare and clean datasets for analysis"""
        # Filter only batting data (balls where striker faced)
        self.batting_data = self.ball_data[self.ball_data['runs_off_bat'].notna()].copy()
        
        # Convert ball column to numeric (handle decimal overs)
        if 'ball' in self.batting_data.columns:
            # Convert ball to numeric (e.g., 1.1 -> 1.1, but we need over number)
            self.batting_data['over_number'] = self.batting_data['ball'].astype(float)
            # Extract over number (integer part)
            self.batting_data['over'] = self.batting_data['over_number'].astype(int)
            # Calculate ball number within over
            self.batting_data['ball_number'] = ((self.batting_data['over_number'] - self.batting_data['over']) * 10).round().astype(int)
            # Calculate total ball position (1-120 for 20 overs)
            self.batting_data['ball_position'] = (self.batting_data['over'] - 1) * 6 + self.batting_data['ball_number']
        
        print(f"✓ Prepared data: {len(self.batting_data)} batting records")
        
