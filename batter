                }
            else:
                type_stats[batter_type] = {'runs': 0, 'balls': 0, 'overs': 0, 'wickets': 0, 'economy': 0, 'average': 0}
        
        # Determine which batter type is more effective against
        if type_stats['Right Hand Bat']['economy'] > 0 and type_stats['Left Hand Bat']['economy'] > 0:
            better_against = 'Left Hand Bat' if type_stats['Right Hand Bat']['economy'] < type_stats['Left Hand Bat']['economy'] else 'Right Hand Bat'
        elif type_stats['Right Hand Bat']['economy'] > 0:
            better_against = 'Right Hand Bat'
        elif type_stats['Left Hand Bat']['economy'] > 0:
            better_against = 'Left Hand Bat'
        else:
            better_against = 'N/A'
        
        return type_stats, better_against
    
    def calculate_head_to_head(self, bowler_name, n=5):
        """Calculate head-to-head statistics against batters"""
        bowler_balls = self.bowling_data[self.bowling_data['bowler'] == bowler_name]
        
        batter_stats = {}
        for batter in bowler_balls['striker'].unique():
            batter_data = bowler_balls[bowler_balls['striker'] == batter]
            if len(batter_data) >= 6:  # Minimum 1 over threshold
                runs = batter_data['runs_off_bat'].sum()
                balls = len(batter_data)
                dismissals = batter_data['wicket_type'].notna().sum()
                economy = (runs / (balls / 6)) if balls > 0 else 0
                
                batter_stats[batter] = {
                    'runs': int(runs),
                    'balls': int(balls),
                    'dismissals': dismissals,
                    'economy': round(economy, 2)
                }
        
        # Sort by balls faced and get top n
        sorted_batters = sorted(batter_stats.items(), key=lambda x: x[1]['balls'], reverse=True)[:n]
        
        # Find most dominated batter (dismissed at least once, lowest runs per ball)
        dominated = None
        dominated_metric = float('inf')
        for batter, stats in batter_stats.items():
            if stats['dismissals'] > 0:
                runs_per_ball = stats['runs'] / stats['balls']
                if runs_per_ball < dominated_metric:
                    dominated_metric = runs_per_ball
                    dominated = batter
        
        # Find most difficult batter (highest runs per ball, min 12 balls)
        difficult = None
        difficult_metric = 0
        for batter, stats in batter_stats.items():
            if stats['balls'] >= 12:
                runs_per_ball = stats['runs'] / stats['balls']
                if runs_per_ball > difficult_metric:
                    difficult_metric = runs_per_ball
                    difficult = batter
        
        return sorted_batters, dominated, difficult
    
    def classify_bowler_style_and_role(self, stats, phase_stats):
        """
        Enhanced classification for bowlers based on phase performance and metrics
        Returns: (bowler_type, primary_phase, specialty, key_metric, role)
        """
        economy = stats['economy']
        strike_rate = stats['strike_rate']
        dot_pct = stats['dot_percentage']
        
        # Get phase economies
        powerplay_econ = phase_stats.get('Powerplay (1-6)', {}).get('economy', 0)
        middle_econ = phase_stats.get('Middle (7-15)', {}).get('economy', 0)
        death_econ = phase_stats.get('Death (16-20)', {}).get('economy', 0)
        
        # Determine primary phase based on best economy
        phase_econs = {
            'Powerplay': powerplay_econ,
            'Middle Overs': middle_econ,
            'Death Overs': death_econ
        }
        # Filter out zero values
        phase_econs = {k: v for k, v in phase_econs.items() if v > 0}
        primary_phase = min(phase_econs, key=phase_econs.get) if phase_econs else "Unknown"
        
        # Determine specialty
        specialties = []
        if powerplay_econ < 7.0 and powerplay_econ > 0:
            specialties.append("Powerplay Specialist")
        if death_econ < 8.5 and death_econ > 0:
            specialties.append("Death Overs Specialist")
        if strike_rate < 20:
            specialties.append("Strike Bowler")
        if economy < 7.5:
            specialties.append("Economy Bowler")
        if dot_pct > 45:
            specialties.append("Containment Specialist")
        
        specialty = ", ".join(specialties) if specialties else "Developing Bowler"
        
        # Determine key metric
        if primary_phase == "Powerplay":
            key_metric = f"Powerplay Economy: {powerplay_econ:.2f}"
        elif primary_phase == "Middle Overs":
            key_metric = f"Middle Overs Economy: {middle_econ:.2f}"
        else:
            key_metric = f"Death Overs Economy: {death_econ:.2f}"
        
        # Classify bowler type
        if death_econ < 8.0 and strike_rate < 18:
            bowler_type = "Elite Death Bowler"
            role = "Death Over Specialist"
        elif strike_rate < 18:
            bowler_type = "Wicket-Taking Bowler"
            role = "Strike Bowler"
        elif economy < 7.2:
            bowler_type = "Economy Bowler"
            role = "Containment Specialist"
        elif powerplay_econ < 6.5:
            bowler_type = "Powerplay Enforcer"
            role = "New Ball Bowler"
        elif death_econ < 9.0:
            bowler_type = "Death Bowler"
            role = "Finisher"
        else:
            bowler_type = "Support Bowler"
            role = "Medium Pacer/Spinner"
        
        return bowler_type, primary_phase, specialty, key_metric, role
    
    def prepare_features_for_ml(self):
        """Prepare features for ML clustering of bowlers"""
        all_bowlers = self.bowling_data['bowler'].unique()
        features_list = []
        bowler_names = []
        
        for bowler in all_bowlers:
            stats = self.get_bowler_stats(bowler)
            if stats and stats['balls'] > 100:  # Minimum balls threshold for meaningful clustering
                phase_stats, _ = self.calculate_best_bowling_phase(bowler)
                
                features = {
                    'economy': stats['economy'],
                    'average': stats['average'],
                    'strike_rate': stats['strike_rate'],
                    'dot_pct': stats['dot_percentage'],
                    'powerplay_econ': phase_stats.get('Powerplay (1-6)', {}).get('economy', 0),
                    'middle_econ': phase_stats.get('Middle (7-15)', {}).get('economy', 0),
                    'death_econ': phase_stats.get('Death (16-20)', {}).get('economy', 0)
                }
                features_list.append(features)
                bowler_names.append(bowler)
                
        return pd.DataFrame(features_list, index=bowler_names)
    
    def perform_kmeans_clustering(self, n_clusters=5):
        """Perform K-means clustering on bowlers"""
        features_df = self.prepare_features_for_ml()
        
        if len(features_df) < n_clusters:
            n_clusters = max(2, len(features_df) - 1)
            
        # Standardize features
        scaler = StandardScaler()
        features_scaled = scaler.fit_transform(features_df)
        
        # K-means clustering
        kmeans = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
        clusters = kmeans.fit_predict(features_scaled)
        
        # Intelligent cluster naming based on bowling characteristics
        cluster_names = {}
        cluster_info = {}
        
        for i in range(n_clusters):
            cluster_data = features_df[clusters == i]
            avg_economy = cluster_data['economy'].mean()
            avg_strike_rate = cluster_data['strike_rate'].mean()
            avg_dot_pct = cluster_data['dot_pct'].mean()
            avg_death_econ = cluster_data['death_econ'].mean()
            avg_powerplay_econ = cluster_data['powerplay_econ'].mean()
            
            # Intelligent cluster naming based on bowling style
            if avg_economy < 7.2 and avg_strike_rate < 18:
                cluster_names[i] = 'Elite Strike Bowlers'
            elif avg_death_econ < 8.0:
                cluster_names[i] = 'Death Overs Specialists'
            elif avg_powerplay_econ < 6.8 and avg_powerplay_econ > 0:
                cluster_names[i] = 'Powerplay Enforcers'
            elif avg_economy < 7.5:
                cluster_names[i] = 'Economy Bowlers'
            elif avg_strike_rate < 20:
                cluster_names[i] = 'Wicket-Taking Bowlers'
            elif avg_dot_pct > 40:
                cluster_names[i] = 'Containment Specialists'
            else:
                cluster_names[i] = 'Developing Bowlers'
            
            cluster_info[i] = {
                'size': len(cluster_data),
                'avg_economy': round(avg_economy, 2),
                'players': features_df.index[clusters == i].tolist()
            }
                
        return clusters, cluster_names, features_df, cluster_info
    
    def find_similar_bowlers(self, bowler_name, n_similar=5):
        """Find similar bowlers using KNN"""
        features_df = self.prepare_features_for_ml()
        
        if bowler_name not in features_df.index:
            return []
            
        # Standardize features
        scaler = StandardScaler()
        features_scaled = scaler.fit_transform(features_df)
        
        # Compute cosine similarity
        player_idx = list(features_df.index).index(bowler_name)
        similarities = cosine_similarity([features_scaled[player_idx]], features_scaled)[0]
        
        # Get top similar players (excluding self)
        similar_indices = np.argsort(similarities)[::-1][1:n_similar+1]
        
        similar_bowlers = []
        for idx in similar_indices:
            similarity = similarities[idx] * 100
            similar_bowlers.append({
                'name': features_df.index[idx],
                'similarity': round(similarity, 2)
            })
            
        return similar_bowlers
    
    def find_bowler_fuzzy(self, input_name):
        """Fuzzy match bowler name and provide suggestions"""
        all_bowlers = list(self.bowling_data['bowler'].unique())
        
        # Exact match (case-insensitive)
        for bowler in all_bowlers:
            if input_name.lower() == bowler.lower():
                return bowler, None
        
        # Fuzzy matching using get_close_matches
        matches = get_close_matches(input_name, all_bowlers, n=5, cutoff=0.4)
        
        if matches:
            print(f"\nBowler '{input_name}' not found. Showing similar names:")
            for i, match in enumerate(matches[:5], 1):
                print(f"  {i}. {match}")
            return None, matches
        
        return None, []
    
