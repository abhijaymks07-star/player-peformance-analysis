    def calculate_league_averages(self):
        """Calculate league averages for phase dominance scoring"""
        for phase, overs in [('Powerplay', (1,6)), ('Middle', (7,15)), ('Death', (16,20))]:
            if 'ball_position' in self.bowling_data.columns:
                phase_data = self.bowling_data[self.bowling_data['ball_position'].between((overs[0]-1)*6+1, overs[1]*6)]
            else:
                phase_data = self.bowling_data[self.bowling_data['ball'].between(overs[0], overs[1])]
                
            if len(phase_data) > 0:
                avg_economy = (phase_data['runs_off_bat'].sum() + phase_data['extras'].sum()) / (len(phase_data) / 6)
                avg_wicket_rate = (phase_data['wicket_type'].notna().sum() / len(phase_data)) * 100
                self.league_averages[phase] = {'economy': avg_economy, 'wicket_rate': avg_wicket_rate}
            else:
                self.league_averages[phase] = {'economy': 0, 'wicket_rate': 0}
            
    def get_bowler_stats(self, bowler_name):
        """Get comprehensive stats for a bowler"""
        # Filter balls bowled by the bowler
        bowler_balls = self.bowling_data[self.bowling_data['bowler'] == bowler_name]
        
        if len(bowler_balls) == 0:
            return None
            
        # Basic stats
        matches = bowler_balls['match_id'].nunique()
        innings = bowler_balls.groupby(['match_id', 'innings']).ngroups
        runs_conceded = bowler_balls['runs_off_bat'].sum() + bowler_balls['extras'].sum()
        balls_bowled = len(bowler_balls)
        overs = balls_bowled / 6
        wickets = bowler_balls['wicket_type'].notna().sum()
        
        economy = runs_conceded / overs if overs > 0 else 0
        average = runs_conceded / wickets if wickets > 0 else 0
        strike_rate = balls_bowled / wickets if wickets > 0 else 0
        
        # Dot ball percentage
        dot_balls = len(bowler_balls[bowler_balls['runs_off_bat'] == 0])
        dot_percentage = (dot_balls / balls_bowled) * 100 if balls_bowled > 0 else 0
        
        # Boundary percentage
        boundaries = bowler_balls[bowler_balls['runs_off_bat'].isin([4,6])]
        boundary_percentage = (len(boundaries) / balls_bowled) * 100 if balls_bowled > 0 else 0
        
        # 4+ wicket hauls
        match_wickets = bowler_balls[bowler_balls['wicket_type'].notna()].groupby('match_id').size()
        four_wicket_hauls = len(match_wickets[match_wickets >= 4])
        five_wicket_hauls = len(match_wickets[match_wickets >= 5])
        
        # Get bowler metadata from mapping
        bowler_info = self.bowler_info_map.get(bowler_name, {})
        bowl_style = bowler_info.get('bowl', 'Unknown')
        bowler_type = bowler_info.get('type', 'Unknown')
        
        return {
            'name': bowler_name,
            'bowl_style': bowl_style,
            'bowler_type': bowler_type,
            'matches': matches,
            'innings': innings,
            'overs': round(overs, 1),
            'balls': balls_bowled,
            'runs': int(runs_conceded),
            'wickets': wickets,
            'economy': round(economy, 2),
            'average': round(average, 2),
            'strike_rate': round(strike_rate, 1),
            'dot_percentage': round(dot_percentage, 2),
            'boundary_percentage': round(boundary_percentage, 2),
            'four_wicket_hauls': four_wicket_hauls,
            'five_wicket_hauls': five_wicket_hauls
        }
        
    def calculate_best_bowling_phase(self, bowler_name):
        """Calculate performance in different bowling phases"""
        bowler_balls = self.bowling_data[self.bowling_data['bowler'] == bowler_name]
        
        phases = {
            'Powerplay (1-6)': (1, 6),
            'Middle (7-15)': (7, 15),
            'Death (16-20)': (16, 20)
        }
        
        phase_stats = {}
        phase_economy = {}
        
        for phase_name, (start, end) in phases.items():
            if 'ball_position' in bowler_balls.columns:
                phase_data = bowler_balls[bowler_balls['ball_position'].between((start-1)*6+1, end*6)]
            else:
                phase_data = bowler_balls[bowler_balls['ball'].between(start, end)]
                
            if len(phase_data) > 0:
                runs = phase_data['runs_off_bat'].sum() + phase_data['extras'].sum()
                balls = len(phase_data)
                overs = balls / 6
                wickets = phase_data['wicket_type'].notna().sum()
                economy = runs / overs if overs > 0 else 0
                dot_balls = (phase_data['runs_off_bat'] == 0).sum()
                dot_pct = (dot_balls / balls) * 100 if balls > 0 else 0
                
                phase_stats[phase_name] = {
                    'runs': int(runs),
                    'balls': int(balls),
                    'overs': round(overs, 1),
                    'wickets': wickets,
                    'economy': round(economy, 2),
                    'dot_pct': round(dot_pct, 2)
                }
                phase_economy[phase_name] = economy
            else:
                phase_stats[phase_name] = {'runs': 0, 'balls': 0, 'overs': 0, 'wickets': 0, 'economy': 0, 'dot_pct': 0}
                phase_economy[phase_name] = 0
                
        best_phase = min(phase_economy, key=phase_economy.get) if max(phase_economy.values()) > 0 else "N/A"
        
        return phase_stats, best_phase
    
    def calculate_phase_dominance_score(self, bowler_name):
        """Calculate phase dominance compared to league averages"""
        bowler_balls = self.bowling_data[self.bowling_data['bowler'] == bowler_name]
        dominance_scores = {}
        
        phases = ['Powerplay', 'Middle', 'Death']
        phase_ranges = [(1,6), (7,15), (16,20)]
        
        for phase, (start, end) in zip(phases, phase_ranges):
            if 'ball_position' in bowler_balls.columns:
                bowler_phase = bowler_balls[bowler_balls['ball_position'].between((start-1)*6+1, end*6)]
            else:
                bowler_phase = bowler_balls[bowler_balls['ball'].between(start, end)]
                
            if len(bowler_phase) > 0:
                bowler_economy = (bowler_phase['runs_off_bat'].sum() + bowler_phase['extras'].sum()) / (len(bowler_phase) / 6)
                bowler_wicket_rate = (bowler_phase['wicket_type'].notna().sum() / len(bowler_phase)) * 100
                
                league_economy = self.league_averages.get(phase, {}).get('economy', 0)
                league_wicket_rate = self.league_averages.get(phase, {}).get('wicket_rate', 0)
                
                if league_economy > 0:
                    econ_dominance = (league_economy / bowler_economy) * 100 if bowler_economy > 0 else 0
                else:
                    econ_dominance = 0
                    
                if league_wicket_rate > 0:
                    wicket_dominance = (bowler_wicket_rate / league_wicket_rate) * 100
                else:
                    wicket_dominance = 0
                    
                # Combined dominance score (lower economy is better, higher wicket rate is better)
                dominance_scores[phase] = round((econ_dominance + wicket_dominance) / 2, 2)
            else:
                dominance_scores[phase] = 0
                
        return dominance_scores
    
    def calculate_pitch_intelligence(self, bowler_name):
        """Calculate venue-based performance for bowler"""
        bowler_balls = self.bowling_data[self.bowling_data['bowler'] == bowler_name]
        
        venue_stats = {}
        for venue in bowler_balls['venue'].unique():
            venue_data = bowler_balls[bowler_balls['venue'] == venue]
            if len(venue_data) >= 12:  # Minimum 2 overs threshold
                runs = venue_data['runs_off_bat'].sum() + venue_data['extras'].sum()
                balls = len(venue_data)
                overs = balls / 6
                wickets = venue_data['wicket_type'].notna().sum()
                economy = runs / overs if overs > 0 else 0
                
                venue_stats[venue] = {
                    'runs': int(runs),
                    'overs': round(overs, 1),
                    'wickets': wickets,
                    'economy': round(economy, 2),
                    'balls': int(balls)
                }
        
        if venue_stats:
            # Sort venues by economy and get best and worst
            sorted_venues = sorted(venue_stats.items(), key=lambda x: x[1]['economy'])
            best_venues = sorted_venues[:2] if len(sorted_venues) >= 2 else sorted_venues
            worst_venues = sorted_venues[-2:] if len(sorted_venues) >= 2 else sorted_venues
            
            # Pitch Intelligence Score (normalized economy across venues)
            avg_economy = np.mean([stats['economy'] for stats in venue_stats.values()])
            pitch_score = max(0, min(100, (1 - (avg_economy - 7) / 5) * 100)) if avg_economy > 0 else 50
            
            return {
                'best_venues': best_venues,
                'worst_venues': worst_venues,
                'pitch_score': round(pitch_score, 2),
                'avg_economy': round(avg_economy, 2)
            }
        return None
    
    def get_batter_hand(self, batter_name):
