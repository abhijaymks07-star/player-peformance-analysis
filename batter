        # Check mapping first
        if batter_name in self.batter_type_map:
            return self.batter_type_map[batter_name]
        
        # Try to get from player data
        player_info = self.player_data[self.player_data['player_name'] == batter_name]
        if len(player_info) > 0:
            bat_style = str(player_info.iloc[0].get('bat_style', ''))
            if 'Left' in bat_style:
                return 'Left Hand Bat'
            elif 'Right' in bat_style:
                return 'Right Hand Bat'
        
        # Default based on name patterns
        left_handers = ['Warner', 'Pant', 'Jadeja', 'Raina', 'Kishan', 'de Kock', 'Shakib']
        for lh in left_handers:
            if lh.lower() in batter_name.lower():
                return 'Left Hand Bat'
        return 'Right Hand Bat'  # Default assumption
    
