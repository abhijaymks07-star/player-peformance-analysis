    def calculate_league_averages(self):
        """Calculate league averages for phase dominance scoring"""
        for phase, overs in [('Powerplay', (1,6)), ('Middle', (7,15)), ('Death', (16,20))]:
            if 'ball_position' in self.batting_data.columns:
                phase_data = self.batting_data[self.batting_data['ball_position'].between((overs[0]-1)*6+1, overs[1]*6)]
            else:
                phase_data = self.batting_data[self.batting_data['ball'].between(overs[0], overs[1])]
                
            if len(phase_data) > 0:
                avg_sr = (phase_data['runs_off_bat'].sum() / len(phase_data)) * 100
                self.league_averages[phase] = {'sr': avg_sr}
            else:
                self.league_averages[phase] = {'sr': 0}
            
    def get_player_stats(self, player_name):
        """Get comprehensive stats for a player"""
        # Filter balls faced by the player
        player_balls = self.batting_data[self.batting_data['striker'] == player_name]
        
        if len(player_balls) == 0:
            return None
            
        # Basic stats
        matches = player_balls['match_id'].nunique()
        innings = player_balls.groupby(['match_id', 'innings']).ngroups
        runs = player_balls['runs_off_bat'].sum()
        balls_faced = len(player_balls)
        dismissals = len(player_balls[player_balls['player_dismissed'] == player_name])
        
        avg = runs / dismissals if dismissals > 0 else runs
        sr = (runs / balls_faced) * 100 if balls_faced > 0 else 0
        
        # Boundary % and Dot %
        boundaries = player_balls[player_balls['runs_off_bat'].isin([4,6])]
        boundary_pct = (len(boundaries) / balls_faced) * 100 if balls_faced > 0 else 0
        dot_pct = (len(player_balls[player_balls['runs_off_bat'] == 0]) / balls_faced) * 100 if balls_faced > 0 else 0
        
        # 50s and 100s
        innings_scores = player_balls.groupby(['match_id', 'innings'])['runs_off_bat'].sum()
        fifties = len(innings_scores[(innings_scores >= 50) & (innings_scores < 100)])
        hundreds = len(innings_scores[innings_scores >= 100])
        
        # Calculate average batting position
        # Approximate batting position based on over of first ball faced
        first_ball_over = player_balls.groupby(['match_id', 'innings'])['over'].min().mean()
        
        # Get player metadata from mapping
        player_info = self.player_info_map.get(player_name, {})
        bat_style = player_info.get('bat', 'Unknown')
        bowl_style = player_info.get('bowl', 'Unknown')
        playing_role = player_info.get('role', 'Unknown')
        batting_position = player_info.get('position', 'Unknown')
        
        # Get batter subtype
        batter_subtype = self.batter_subtype_map.get(player_name, 'Standard Batter')
        
        return {
            'name': player_name,
            'bat_style': bat_style,
            'bowl_style': bowl_style,
            'playing_role': playing_role,
            'batting_position': batting_position,
            'batter_subtype': batter_subtype,
            'avg_position': round(first_ball_over, 1) if not np.isnan(first_ball_over) else 0,
            'matches': matches,
            'innings': innings,
            'runs': int(runs),
            'balls_faced': int(balls_faced),
            'average': round(avg, 2),
            'strike_rate': round(sr, 2),
            'boundary_pct': round(boundary_pct, 2),
            'dot_pct': round(dot_pct, 2),
            'fifties': fifties,
            'hundreds': hundreds,
            'dismissals': dismissals
        }
        
    def calculate_best_batting_phase(self, player_name):
        """Calculate performance in different batting phases"""
        player_balls = self.batting_data[self.batting_data['striker'] == player_name]
        
        phases = {
            'Powerplay (1-6)': (1, 6),
            'Middle (7-15)': (7, 15),
            'Death (16-20)': (16, 20)
        }
        
        phase_stats = {}
        phase_runs = {}
        
        for phase_name, (start, end) in phases.items():
            if 'ball_position' in player_balls.columns:
                phase_data = player_balls[player_balls['ball_position'].between((start-1)*6+1, end*6)]
            else:
                phase_data = player_balls[player_balls['ball'].between(start, end)]
                
            if len(phase_data) > 0:
                runs = phase_data['runs_off_bat'].sum()
                balls = len(phase_data)
                dismissals = len(phase_data[phase_data['player_dismissed'] == player_name])
                sr = (runs / balls) * 100 if balls > 0 else 0
                avg = runs / dismissals if dismissals > 0 else runs
                boundaries = len(phase_data[phase_data['runs_off_bat'].isin([4,6])])
                dots = len(phase_data[phase_data['runs_off_bat'] == 0])
                
                phase_stats[phase_name] = {
                    'runs': int(runs),
                    'balls': int(balls),
                    'sr': round(sr, 2),
                    'avg': round(avg, 2),
                    'boundaries': boundaries,
                    'dots': dots,
                    'boundary_pct': round((boundaries / balls) * 100, 2) if balls > 0 else 0,
                    'dot_pct': round((dots / balls) * 100, 2) if balls > 0 else 0
                }
                phase_runs[phase_name] = runs
            else:
                phase_stats[phase_name] = {'runs': 0, 'balls': 0, 'sr': 0, 'avg': 0, 'boundaries': 0, 'dots': 0, 'boundary_pct': 0, 'dot_pct': 0}
                phase_runs[phase_name] = 0
                
        # BEST PHASE BASED ON RUNS SCORED (most runs in that phase)
        best_phase = max(phase_runs, key=phase_runs.get) if max(phase_runs.values()) > 0 else "N/A"
        
        return phase_stats, best_phase
    
    def calculate_phase_dominance_score(self, player_name):
        """Calculate phase dominance compared to league averages"""
        player_balls = self.batting_data[self.batting_data['striker'] == player_name]
        dominance_scores = {}
        
        phases = ['Powerplay', 'Middle', 'Death']
        phase_ranges = [(1,6), (7,15), (16,20)]
        
        for phase, (start, end) in zip(phases, phase_ranges):
            if 'ball_position' in player_balls.columns:
                player_phase = player_balls[player_balls['ball_position'].between((start-1)*6+1, end*6)]
            else:
                player_phase = player_balls[player_balls['ball'].between(start, end)]
                
            if len(player_phase) > 0:
                player_sr = (player_phase['runs_off_bat'].sum() / len(player_phase)) * 100
                league_sr = self.league_averages.get(phase, {}).get('sr', 0)
                if league_sr > 0:
                    dominance = (player_sr / league_sr) * 100
                    dominance_scores[phase] = round(dominance, 2)
                else:
                    dominance_scores[phase] = 0
            else:
                dominance_scores[phase] = 0
                
        return dominance_scores
    
    def calculate_pitch_intelligence(self, player_name):
        """Calculate venue-based performance - returns top 3 best and top 3 worst venues"""
        player_balls = self.batting_data[self.batting_data['striker'] == player_name]
        
        venue_stats = {}
        for venue in player_balls['venue'].unique():
            venue_data = player_balls[player_balls['venue'] == venue]
            if len(venue_data) >= 5:  # Minimum balls threshold
                runs = venue_data['runs_off_bat'].sum()
                balls = len(venue_data)
                dismissals = len(venue_data[venue_data['player_dismissed'] == player_name])
                avg = runs / dismissals if dismissals > 0 else runs
                sr = (runs / balls) * 100 if balls > 0 else 0
                boundaries = len(venue_data[venue_data['runs_off_bat'].isin([4,6])])
                
                venue_stats[venue] = {
                    'runs': int(runs),
                    'avg': round(avg, 2),
                    'sr': round(sr, 2),
                    'balls': int(balls),
                    'boundaries': boundaries,
                    'matches': venue_data['match_id'].nunique()
                }
        
        if venue_stats:
            # Sort venues by SR and get top 3 and bottom 3
            sorted_venues = sorted(venue_stats.items(), key=lambda x: x[1]['sr'], reverse=True)
            best_venues = sorted_venues[:3] if len(sorted_venues) >= 3 else sorted_venues
            worst_venues = sorted_venues[-3:] if len(sorted_venues) >= 3 else sorted_venues
            
            # Pitch Intelligence Score (normalized performance across venues)
            avg_sr = np.mean([stats['sr'] for stats in venue_stats.values()])
            pitch_score = min(100, max(0, (avg_sr / 140) * 100)) if avg_sr > 0 else 0
            
            return {
                'best_venues': best_venues,
                'worst_venues': worst_venues,
                'pitch_score': round(pitch_score, 2),
                'avg_sr': round(avg_sr, 2),
                'total_venues': len(venue_stats)
            }
        return None
    
    def calculate_vulnerability_index(self, player_name):
        """Calculate vulnerability against different bowler types - Enhanced with more metrics"""
        player_balls = self.batting_data[self.batting_data['striker'] == player_name]
        
        # Bowler type categories - all 4 types
        bowler_types = ['Right Arm Pace', 'Left Arm Pace', 'Right Arm Spin', 'Left Arm Spin']
        
        # Initialize stats for each bowler type with default values
        type_stats = {}
        for bowl_type in bowler_types:
            type_stats[bowl_type] = {
                'sr': 0, 'avg': 0, 'balls': 0, 'runs': 0, 'dismissals': 0, 
                'vulnerability_score': 0, 'boundaries': 0, 'dots': 0,
                'boundary_pct': 0, 'dot_pct': 0, 'runs_per_ball': 0
            }
        
        # Find bowlers of each type from the mapping
        for bowl_type in bowler_types:
            bowlers_of_type = [b for b, t in self.bowler_style_map.items() if t == bowl_type]
            
            if bowlers_of_type:
                type_data = player_balls[player_balls['bowler'].isin(bowlers_of_type)]
            else:
                type_data = pd.DataFrame()
            
            if len(type_data) > 0:
                runs = type_data['runs_off_bat'].sum()
                balls = len(type_data)
                dismissals = len(type_data[type_data['player_dismissed'] == player_name])
                boundaries = len(type_data[type_data['runs_off_bat'].isin([4,6])])
                dots = len(type_data[type_data['runs_off_bat'] == 0])
                sr = (runs / balls) * 100 if balls > 0 else 0
                avg = runs / dismissals if dismissals > 0 else runs
                dismissals_per_100 = (dismissals / balls) * 100 if balls > 0 else 0
                runs_per_ball = runs / balls if balls > 0 else 0
                
                type_stats[bowl_type] = {
                    'runs': int(runs),
                    'balls': int(balls),
                    'dismissals': dismissals,
                    'sr': round(sr, 2),
                    'avg': round(avg, 2),
                    'vulnerability_score': round(dismissals_per_100, 2),
                    'boundaries': boundaries,
                    'dots': dots,
                    'boundary_pct': round((boundaries / balls) * 100, 2) if balls > 0 else 0,
                    'dot_pct': round((dots / balls) * 100, 2) if balls > 0 else 0,
                    'runs_per_ball': round(runs_per_ball, 2)
                }
        
        # Find best, worst, and rankings based on strike rate (only consider types with balls > 10)
        valid_types = {k: v for k, v in type_stats.items() if v['balls'] > 10}
        
        if valid_types:
            # Sort by strike rate (higher is better for batter)
            sorted_by_sr = sorted(valid_types.items(), key=lambda x: x[1]['sr'], reverse=True)
            
            best_against = sorted_by_sr[0][0] if sorted_by_sr else 'N/A'
            worst_against = sorted_by_sr[-1][0] if sorted_by_sr else 'N/A'
            most_vulnerable = max(valid_types.items(), key=lambda x: x[1]['vulnerability_score'])[0]
            
            # Second best and second worst
            second_best = sorted_by_sr[1][0] if len(sorted_by_sr) > 1 else 'N/A'
            second_worst = sorted_by_sr[-2][0] if len(sorted_by_sr) > 1 else 'N/A'
            
            # Calculate overall vulnerability index (weighted average of vulnerability scores)
            total_balls = sum(v['balls'] for v in valid_types.values())
            vulnerability_index = sum(v['vulnerability_score'] * v['balls'] for v in valid_types.values()) / total_balls if total_balls > 0 else 0
            
            # Calculate performance consistency (standard deviation of strike rates)
            sr_values = [v['sr'] for v in valid_types.values()]
            consistency_score = 100 - (np.std(sr_values) * 2) if len(sr_values) > 1 else 50
            consistency_score = max(0, min(100, consistency_score))
            
            return {
                'best_against': best_against,
                'best_stats': valid_types[best_against],
                'second_best': second_best,
                'second_best_stats': valid_types[second_best] if second_best != 'N/A' else None,
                'worst_against': worst_against,
                'worst_stats': valid_types[worst_against],
                'second_worst': second_worst,
                'second_worst_stats': valid_types[second_worst] if second_worst != 'N/A' else None,
                'most_vulnerable': most_vulnerable,
                'all_stats': type_stats,
                'vulnerability_index': round(vulnerability_index, 2),
                'consistency_score': round(consistency_score, 2),
                'sorted_by_sr': sorted_by_sr
            }
        
        return {
            'best_against': 'N/A',
            'worst_against': 'N/A',
            'most_vulnerable': 'N/A',
            'all_stats': type_stats,
            'vulnerability_index': 0,
            'consistency_score': 0
        }
    
    def classify_batter_style_and_role(self, stats, phase_stats, best_phase):
        """
        Enhanced classification based on WHERE the player scores most runs (best phase)
        A player is a "Death Over Specialist" if they score most of their runs in death overs
        
        Returns: (batter_type, primary_phase, target_bowlers, key_metric, role)
        """
        sr = stats['strike_rate']
        boundary_pct = stats['boundary_pct']
        dot_pct = stats['dot_pct']
        
        # Get phase stats
        powerplay_runs = phase_stats.get('Powerplay (1-6)', {}).get('runs', 0)
        middle_runs = phase_stats.get('Middle (7-15)', {}).get('runs', 0)
        death_runs = phase_stats.get('Death (16-20)', {}).get('runs', 0)
        
        powerplay_sr = phase_stats.get('Powerplay (1-6)', {}).get('sr', 0)
        middle_sr = phase_stats.get('Middle (7-15)', {}).get('sr', 0)
        death_sr = phase_stats.get('Death (16-20)', {}).get('sr', 0)
        
        total_runs = powerplay_runs + middle_runs + death_runs
        
        # Calculate percentage of runs in each phase
        powerplay_pct = (powerplay_runs / total_runs * 100) if total_runs > 0 else 0
        middle_pct = (middle_runs / total_runs * 100) if total_runs > 0 else 0
        death_pct = (death_runs / total_runs * 100) if total_runs > 0 else 0        
        # Determine primary phase based on where most runs are scored
        primary_phase = best_phase if best_phase != "N/A" else "Unknown"
        
        # Determine target bowlers based on phase performance
        target_bowlers = []
        if powerplay_pct > 35 and powerplay_sr > 130:
            target_bowlers.append("Pace Bowlers")
        if middle_pct > 35 and middle_sr > 125:
            target_bowlers.append("Spin Bowlers")
        if death_pct > 35 and death_sr > 140:
            target_bowlers.append("Death Bowlers")
        
        target_bowlers_str = ", ".join(target_bowlers) if target_bowlers else "All Types"
        
        # Determine key metric based on primary phase
        if primary_phase == "Powerplay (1-6)":
            key_metric = f"Powerplay Runs: {powerplay_runs} ({powerplay_pct:.1f}%) | SR: {powerplay_sr:.1f}"
        elif primary_phase == "Middle (7-15)":
            key_metric = f"Middle Runs: {middle_runs} ({middle_pct:.1f}%) | SR vs Spin: {middle_sr:.1f}"
        else:  # Death (16-20)
            key_metric = f"Death Runs: {death_runs} ({death_pct:.1f}%) | Death SR: {death_sr:.1f}"
        
        # Classify batter type based on PRIMARY PHASE (where most runs are scored)
        if primary_phase == "Death (16-20)":
            batter_type = "Death Over Specialist"
            role = "Finisher"
        elif primary_phase == "Powerplay (1-6)":
            batter_type = "Powerplay Specialist"
            role = "Opener"
        elif primary_phase == "Middle (7-15)":
            if middle_sr > 130:
                batter_type = "Spin Dominator"
                role = "Middle Order Batter"
            else:
                batter_type = "Anchor"
                role = "Middle Order Batter"
        else:
            # Fallback based on strike rate
            if sr > 140:
                batter_type = "Aggressive Batter"
                role = "All-round Batter"
            elif sr > 130:
                batter_type = "Accumulator"
                role = "Top/Middle Order"
            else:
                batter_type = "Defensive Batter"
                role = "Lower Order"
        
        return batter_type, primary_phase, target_bowlers_str, key_metric, role
    
    def prepare_features_for_ml(self):
        """Prepare features for ML clustering"""
        all_players = self.batting_data['striker'].unique()
        features_list = []
        player_names = []
        
        for player in all_players:
            stats = self.get_player_stats(player)
            if stats and stats['balls_faced'] > 50:  # Minimum balls threshold for meaningful clustering
                phase_stats, _ = self.calculate_best_batting_phase(player)
                
                features = {
                    'strike_rate': stats['strike_rate'],
                    'average': stats['average'],
                    'boundary_pct': stats['boundary_pct'],
                    'dot_pct': stats['dot_pct'],
                    'powerplay_sr': phase_stats.get('Powerplay (1-6)', {}).get('sr', 0),
                    'middle_sr': phase_stats.get('Middle (7-15)', {}).get('sr', 0),
                    'death_sr': phase_stats.get('Death (16-20)', {}).get('sr', 0),
                    'powerplay_runs': phase_stats.get('Powerplay (1-6)', {}).get('runs', 0),
                    'middle_runs': phase_stats.get('Middle (7-15)', {}).get('runs', 0),
                    'death_runs': phase_stats.get('Death (16-20)', {}).get('runs', 0)
                }
                features_list.append(features)
                player_names.append(player)
                
        return pd.DataFrame(features_list, index=player_names)
    
    def perform_kmeans_clustering(self, n_clusters=5):
        """Perform K-means clustering on players"""
        features_df = self.prepare_features_for_ml()
        
        if len(features_df) < n_clusters:
            n_clusters = max(2, len(features_df) - 1)
            
        # Standardize features
        scaler = StandardScaler()
        features_scaled = scaler.fit_transform(features_df)
        
        # K-means clustering
        kmeans = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
        clusters = kmeans.fit_predict(features_scaled)
        
        # Improved cluster naming based on actual characteristics
        cluster_names = {}
        cluster_info = {}
        
        for i in range(n_clusters):
            cluster_data = features_df[clusters == i]
            avg_sr = cluster_data['strike_rate'].mean()
            avg_boundary = cluster_data['boundary_pct'].mean()
            avg_death_sr = cluster_data['death_sr'].mean()
            avg_powerplay_sr = cluster_data['powerplay_sr'].mean()
            avg_middle_sr = cluster_data['middle_sr'].mean()
            avg_death_runs = cluster_data['death_runs'].mean()
            avg_powerplay_runs = cluster_data['powerplay_runs'].mean()
            avg_middle_runs = cluster_data['middle_runs'].mean()
            
            # Determine primary phase for the cluster
            if avg_death_runs > avg_powerplay_runs and avg_death_runs > avg_middle_runs:
                cluster_names[i] = 'Death Over Specialists'
            elif avg_powerplay_runs > avg_middle_runs and avg_powerplay_runs > avg_death_runs:
                cluster_names[i] = 'Powerplay Specialists'
            elif avg_middle_runs > avg_powerplay_runs and avg_middle_runs > avg_death_runs:
                cluster_names[i] = 'Middle Order Anchors'
            elif avg_sr > 140 and avg_boundary > 18:
                cluster_names[i] = 'Elite Aggressive Batters'
            elif avg_sr < 120:
                cluster_names[i] = 'Defensive Anchors'
            else:
                cluster_names[i] = 'Versatile Batters'
            
            cluster_info[i] = {
                'size': len(cluster_data),
                'avg_sr': round(avg_sr, 2),
                'players': features_df.index[clusters == i].tolist()
            }
                
        return clusters, cluster_names, features_df, cluster_info
    
    def find_similar_players(self, player_name, n_similar=5):
        """Find similar players using KNN"""
        features_df = self.prepare_features_for_ml()
        
        if player_name not in features_df.index:
            return []
            
        # Standardize features
        scaler = StandardScaler()
        features_scaled = scaler.fit_transform(features_df)
        
        # Compute cosine similarity
        player_idx = list(features_df.index).index(player_name)
        similarities = cosine_similarity([features_scaled[player_idx]], features_scaled)[0]
        
        # Get top similar players (excluding self)
        similar_indices = np.argsort(similarities)[::-1][1:n_similar+1]
        
        similar_players = []
        for idx in similar_indices:
            similarity = similarities[idx] * 100
            similar_players.append({
                'name': features_df.index[idx],
                'similarity': round(similarity, 2)
            })
            
        return similar_players
    
    def find_player_fuzzy(self, input_name):
