    def classify_bowler_type(self, bowl_style):
        """Classify bowler type based on bowling style"""
        bowl_style_lower = str(bowl_style).lower()
        
        if 'leg' in bowl_style_lower or 'wrist' in bowl_style_lower:
            if 'left' in bowl_style_lower:
                return 'Chinaman'
            return 'Leg Spinner'
        elif 'off' in bowl_style_lower:
            return 'Off Spinner'
        elif 'orthodox' in bowl_style_lower or 'left arm' in bowl_style_lower:
            return 'Left Arm Spinner'
        elif 'fast' in bowl_style_lower:
            return 'Fast Bowler'
        elif 'medium' in bowl_style_lower:
            return 'Medium Pacer'
        else:
            return 'Unknown'
        
