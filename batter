    def calculate_impact_score(self, stats, phase_stats):
        """Calculate overall bowling impact score (0-100)"""
        # Economy score (lower economy is better)
        economy_score = max(0, min(100, (1 - (stats['economy'] - 6) / 6) * 100))
        
        # Wicket score (more wickets per match is better)
        wickets_per_match = stats['wickets'] / stats['matches']
        wicket_score = min(100, (wickets_per_match / 2) * 100)
        
        # Strike rate score (lower strike rate is better)
        sr_score = max(0, min(100, (1 - (stats['strike_rate'] - 15) / 25) * 100))
        
        # Dot ball score
        dot_score = min(100, (stats['dot_percentage'] / 50) * 100)
        
        # Phase performance score
        death_econ = phase_stats.get('Death (16-20)', {}).get('economy', 10)
        death_score = max(0, min(100, (1 - (death_econ - 8) / 6) * 100))
        
        # Weighted average
        impact = (economy_score * 0.3) + (wicket_score * 0.3) + (sr_score * 0.2) + (dot_score * 0.1) + (death_score * 0.1)
        return round(impact, 2)


