    def classify_bowler_type(self, bowl_style):
        """Classify bowler type based on bowling style string"""
        if pd.isna(bowl_style) or bowl_style == 'Unknown' or bowl_style == 'None':
            return None
        
        bowl_style_lower = str(bowl_style).lower()
        
        # Check for Left Arm Pace first
        if 'left arm fast' in bowl_style_lower or 'left arm medium' in bowl_style_lower or 'left arm fast medium' in bowl_style_lower:
            return 'Left Arm Pace'
        
        # Check for Right Arm Pace
        if 'right arm fast' in bowl_style_lower or 'right arm medium' in bowl_style_lower or 'right arm fast medium' in bowl_style_lower:
            return 'Right Arm Pace'
        
        # Check for Left Arm Spin
        if 'left arm offbreak' in bowl_style_lower or 'left arm orthodox' in bowl_style_lower or 'left arm wrist spin' in bowl_style_lower or 'slow left arm' in bowl_style_lower:
            return 'Left Arm Spin'
        
        # Check for Right Arm Spin
        if 'right arm offbreak' in bowl_style_lower or 'legbreak' in bowl_style_lower or 'right arm wrist spin' in bowl_style_lower or 'leg break' in bowl_style_lower:
            return 'Right Arm Spin'
        
        return None
        
