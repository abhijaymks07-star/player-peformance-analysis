        # Clean up None values
        all_players = [p for p in all_players if p and pd.notna(p)]
        
        # Exact match (case-insensitive)
        for player in all_players:
            if input_name.lower() == player.lower():
                return player, None
        
        # Fuzzy matching using get_close_matches
        matches = get_close_matches(input_name, all_players, n=5, cutoff=0.3)
        
        if matches:
            print(f"\nPlayer '{input_name}' not found. Showing similar names:")
