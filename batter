    def prepare_data(self):
        """Prepare and clean datasets for analysis"""
        # Filter only bowling data
        self.bowling_data = self.ball_data[self.ball_data['bowler'].notna()].copy()
        
        # Convert ball column to numeric (handle decimal overs)
        if 'ball' in self.bowling_data.columns:
            # Convert ball to numeric (e.g., 1.1 -> 1.1, but we need over number)
            self.bowling_data['over_number'] = self.bowling_data['ball'].astype(float)
            # Extract over number (integer part)
            self.bowling_data['over'] = self.bowling_data['over_number'].astype(int)
            # Calculate ball number within over
            self.bowling_data['ball_number'] = ((self.bowling_data['over_number'] - self.bowling_data['over']) * 10).round().astype(int)
            # Calculate total ball position (1-120 for 20 overs)
            self.bowling_data['ball_position'] = (self.bowling_data['over'] - 1) * 6 + self.bowling_data['ball_number']
        
        print(f"✓ Prepared data: {len(self.bowling_data)} bowling records")
        
